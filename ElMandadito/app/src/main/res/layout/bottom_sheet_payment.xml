<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingTop="8dp">

    <!-- Handle -->
    <View
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/divider" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Método de pago"
            android:textColor="@color/brown_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_close_payment"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_close"
            android:tint="@color/text_secondary"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Cerrar" />

    </LinearLayout>

    <!-- Order total + delivery address summary -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_meta_row"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:padding="14dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total a pagar"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/text_payment_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textColor="@color/primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:src="@drawable/ic_location"
                android:tint="@color/primary"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entregar en: "
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <TextView
                android:id="@+id/text_delivery_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Colonia Centro, CDMX"
                android:textColor="@color/brown_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

    </LinearLayout>

    <!-- Items breakdown label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="8dp"
        android:text="RESUMEN DEL PEDIDO"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.06" />

    <!-- Items breakdown (populated programmatically) -->
    <LinearLayout
        android:id="@+id/layout_order_items_breakdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp" />

    <!-- Payment options label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        android:text="SELECCIONA TU FORMA DE PAGO"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.06" />

    <!-- Payment options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <!-- Cash -->
        <LinearLayout
            android:id="@+id/option_cash"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_payment_option"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_meta_row">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_cash"
                    android:tint="@color/success" android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Efectivo" android:textColor="@color/brown_dark"
                    android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Paga al recibir tu pedido"
                    android:textColor="@color/text_secondary" android:textSize="11sp" />
            </LinearLayout>
            <View android:id="@+id/check_cash" android:layout_width="20dp" android:layout_height="20dp"
                android:background="@drawable/bg_step_done" android:visibility="gone" />
        </LinearLayout>

        <!-- Card -->
        <LinearLayout
            android:id="@+id/option_card"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_payment_option"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_meta_row">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_credit_card"
                    android:tint="@color/primary" android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tarjeta" android:textColor="@color/brown_dark"
                    android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Débito o crédito"
                    android:textColor="@color/text_secondary" android:textSize="11sp" />
            </LinearLayout>
            <View android:id="@+id/check_card" android:layout_width="20dp" android:layout_height="20dp"
                android:background="@drawable/bg_step_done" android:visibility="gone" />
        </LinearLayout>

        <!-- OXXO -->
        <LinearLayout
            android:id="@+id/option_oxxo"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/bg_payment_option"
            android:clickable="true"
            android:focusable="true">
            <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_meta_row">
                <ImageView android:layout_width="24dp" android:layout_height="24dp"
                    android:layout_gravity="center" android:src="@drawable/ic_oxxo"
                    android:contentDescription="@null" />
            </FrameLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="12dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="OXXO" android:textColor="@color/brown_dark"
                    android:textSize="14sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Paga en tienda de conveniencia"
                    android:textColor="@color/text_secondary" android:textSize="11sp" />
            </LinearLayout>
            <View android:id="@+id/check_oxxo" android:layout_width="20dp" android:layout_height="20dp"
                android:background="@drawable/bg_step_done" android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

    <!-- Confirm button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <Button
            android:id="@+id/btn_confirm_payment"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_checkout_btn"
            android:text="Confirmar pedido"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>
