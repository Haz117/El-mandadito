<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingBottom="40dp">

        <!-- Logo -->
        <FrameLayout
            android:id="@+id/layout_logo"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginTop="52dp"
            android:background="@drawable/bg_icon_light">
            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_scooter"
                android:tint="#1A1A1A"
                android:contentDescription="@null" />
        </FrameLayout>

        <!-- Headline -->
        <TextView
            android:id="@+id/text_headline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Crea tu\ncuenta"
            android:textColor="#1A1A1A"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:lineSpacingMultiplier="1.1"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="Regístrate y empieza a pedir"
            android:textColor="#6B6B6B"
            android:textSize="14sp" />

        <!-- Name -->
        <LinearLayout
            android:id="@+id/layout_name"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_person"
                android:tint="#A0A0A0"
                android:contentDescription="@null"
                android:layout_marginEnd="12dp" />

            <EditText
                android:id="@+id/edit_name"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Tu nombre"
                android:textColorHint="#A0A0A0"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:inputType="textPersonName|textCapWords"
                android:singleLine="true"
                android:imeOptions="actionNext" />
        </LinearLayout>

        <!-- Email -->
        <LinearLayout
            android:id="@+id/layout_email"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_receipt"
                android:tint="#A0A0A0"
                android:contentDescription="@null"
                android:layout_marginEnd="12dp" />

            <EditText
                android:id="@+id/edit_email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Correo electrónico"
                android:textColorHint="#A0A0A0"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:inputType="textEmailAddress"
                android:singleLine="true"
                android:imeOptions="actionNext" />
        </LinearLayout>

        <!-- Password -->
        <LinearLayout
            android:id="@+id/layout_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_tag"
                android:tint="#A0A0A0"
                android:contentDescription="@null"
                android:layout_marginEnd="12dp" />

            <EditText
                android:id="@+id/edit_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Contraseña (mín. 6 caracteres)"
                android:textColorHint="#A0A0A0"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:imeOptions="actionNext" />

            <ImageView
                android:id="@+id/btn_toggle_password"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_eye"
                android:padding="7dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Mostrar contraseña" />
        </LinearLayout>

        <!-- CURP -->
        <LinearLayout
            android:id="@+id/layout_curp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="14dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_tag"
                android:tint="#A0A0A0"
                android:contentDescription="@null"
                android:layout_marginEnd="12dp" />

            <EditText
                android:id="@+id/edit_curp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="CURP (18 caracteres)"
                android:textColorHint="#A0A0A0"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:inputType="textCapCharacters"
                android:maxLength="18"
                android:singleLine="true"
                android:imeOptions="actionNext" />
        </LinearLayout>

        <!-- Confirm Password -->
        <LinearLayout
            android:id="@+id/layout_confirm_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="22dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_check_circle"
                android:tint="#A0A0A0"
                android:contentDescription="@null"
                android:layout_marginEnd="12dp" />

            <EditText
                android:id="@+id/edit_confirm_password"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Confirmar contraseña"
                android:textColorHint="#A0A0A0"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:inputType="textPassword"
                android:singleLine="true"
                android:imeOptions="actionDone" />

            <ImageView
                android:id="@+id/btn_toggle_confirm_password"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_eye"
                android:padding="7dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Mostrar contraseña" />
        </LinearLayout>

        <!-- Error -->
        <TextView
            android:id="@+id/text_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E53935"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="14dp"
            android:visibility="gone" />

        <!-- Button -->
        <Button
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_checkout_btn"
            android:text="Crear cuenta"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:textAllCaps="false"
            android:letterSpacing="0.01"
            android:layout_marginBottom="28dp" />

        <!-- Login link -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Ya tienes cuenta? "
                android:textColor="#6B6B6B"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_go_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Iniciar sesión"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
