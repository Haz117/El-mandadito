<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="260dp"
    android:layout_height="140dp"
    android:layout_marginEnd="14dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="22dp"
    app:cardElevation="6dp"
    app:strokeWidth="0dp">

    <!-- Colored background (set in code) -->
    <View
        android:id="@+id/view_featured_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Decorative circles for depth -->
    <View
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-40dp"
        android:background="#1AFFFFFF" />

    <View
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-25dp"
        android:layout_marginBottom="-25dp"
        android:background="#10FFFFFF" />

    <!-- Bottom text scrim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_image_scrim" />

    <!-- Content overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Badge: top -->
        <TextView
            android:id="@+id/text_featured_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#33FFFFFF"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Title + subtitle: bottom -->
        <TextView
            android:id="@+id/text_featured_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:lineSpacingMultiplier="1.1"
            android:letterSpacing="-0.01" />

        <TextView
            android:id="@+id/text_featured_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
