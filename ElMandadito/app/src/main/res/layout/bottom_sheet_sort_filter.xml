<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingTop="8dp"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View android:layout_width="44dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal" android:layout_marginBottom="8dp"
        android:background="@color/divider" />

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp" android:paddingBottom="12dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Ordenar y filtrar"
            android:textColor="@color/brown_dark" android:textSize="20sp" android:textStyle="bold" />
        <TextView android:id="@+id/btn_reset_filters" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Limpiar"
            android:textColor="@color/primary" android:textSize="14sp"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" android:layout_marginBottom="16dp" />

    <!-- Sort section -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginBottom="10dp"
        android:text="ORDENAR POR" android:textColor="@color/text_secondary"
        android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1" />

    <RadioGroup android:id="@+id/radio_sort"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp">

        <RadioButton android:id="@+id/sort_default"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Por defecto" android:textColor="@color/brown_dark" android:textSize="14sp"
            android:checked="true" android:buttonTint="@color/primary" />

        <RadioButton android:id="@+id/sort_rating"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Mejor valorado" android:textColor="@color/brown_dark" android:textSize="14sp"
            android:buttonTint="@color/primary" />

        <RadioButton android:id="@+id/sort_time"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Más rápido" android:textColor="@color/brown_dark" android:textSize="14sp"
            android:buttonTint="@color/primary" />

        <RadioButton android:id="@+id/sort_fee"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Menor costo de envío" android:textColor="@color/brown_dark" android:textSize="14sp"
            android:buttonTint="@color/primary" />

    </RadioGroup>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider" android:layout_marginVertical="12dp" />

    <!-- Filter section -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginBottom="10dp"
        android:text="FILTROS" android:textColor="@color/text_secondary"
        android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Solo envío gratis"
            android:textColor="@color/brown_dark" android:textSize="14sp" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_free_delivery"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:thumbTint="@color/primary" android:trackTint="@color/switch_track_color" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="20dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="Solo restaurantes abiertos"
            android:textColor="@color/brown_dark" android:textSize="14sp" />
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_open_only"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:checked="true" android:thumbTint="@color/primary" android:trackTint="@color/switch_track_color" />
    </LinearLayout>

    <Button android:id="@+id/btn_apply_filters"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp"
        android:background="@drawable/bg_checkout_btn"
        android:text="Aplicar filtros"
        android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold" />

</LinearLayout>
