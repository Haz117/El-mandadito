<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<androidx.core.widget.NestedScrollView
    android:id="@+id/nested_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- =========== HERO =========== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero">

            <!-- Decorative circles -->
            <View
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-80dp"
                android:layout_marginEnd="-80dp"
                android:background="#14FFFFFF" />

            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-30dp"
                android:layout_marginBottom="10dp"
                android:background="#0DFFFFFF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="24dp"
                android:paddingBottom="52dp">

                <!-- Top bar: delivery address + cart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Address block — tappable to change -->
                    <LinearLayout
                        android:id="@+id/btn_change_address"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="13dp"
                                android:layout_height="13dp"
                                android:src="@drawable/ic_location"
                                android:tint="#FFE0B2"
                                android:contentDescription="@null" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="Entregando en"
                                android:textColor="#FFE0B2"
                                android:textSize="11sp"
                                android:letterSpacing="0.03" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <TextView
                                android:id="@+id/text_delivery_address_header"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Colonia Centro, CDMX"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:maxLines="1"
                                android:ellipsize="end" />

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/ic_chevron_right"
                                android:rotation="90"
                                android:tint="#FFE0B2"
                                android:contentDescription="@null" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Cart button — frosted circular -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp">

                        <ImageView
                            android:id="@+id/btn_header_cart"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:src="@drawable/ic_cart"
                            android:tint="@color/primary"
                            android:padding="11dp"
                            android:background="@drawable/bg_frosted_pill"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Carrito" />

                        <TextView
                            android:id="@+id/badge_header_cart"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="2dp"
                            android:layout_marginEnd="2dp"
                            android:background="@drawable/bg_cart_badge"
                            android:text="0"
                            android:textColor="#FFFFFF"
                            android:textSize="9sp"
                            android:gravity="center"
                            android:visibility="gone" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Greeting -->
                <TextView
                    android:id="@+id/text_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="¿Qué quieres comer hoy?"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:lineSpacingMultiplier="1.15"
                    android:letterSpacing="-0.01"
                    android:layout_marginBottom="18dp" />

                <!-- Search bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_search"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="8dp"
                    android:gravity="center_vertical"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        android:tint="#A0A0A0"
                        android:contentDescription="@null" />

                    <EditText
                        android:id="@+id/edit_search"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Restaurantes, platillos..."
                        android:textColorHint="#A0A0A0"
                        android:textColor="@color/brown_dark"
                        android:textSize="14sp"
                        android:paddingStart="10dp"
                        android:paddingEnd="4dp"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:singleLine="true" />

                    <ImageView
                        android:id="@+id/btn_clear_search"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_close"
                        android:padding="8dp"
                        android:contentDescription="Limpiar"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>
        </FrameLayout>

        <!-- Curva de transición -->
        <View
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginTop="-28dp"
            android:background="@color/background" />

        <!-- =========== FEATURED DEALS =========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingBottom="12dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="20dp"
                    android:background="@color/primary"
                    android:layout_marginEnd="10dp" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_fire"
                    android:tint="@color/accent"
                    android:contentDescription="@null"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ofertas del día"
                    android:textColor="@color/brown_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_featured"
                android:layout_width="match_parent"
                android:layout_height="162dp"
                android:paddingStart="22dp"
                android:paddingEnd="8dp"
                android:clipToPadding="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:spanCount="1" />
        </LinearLayout>

        <!-- =========== CATEGORÍAS =========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="22dp"
            android:paddingBottom="12dp">

            <View
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="@color/primary"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Categorías"
                android:textColor="@color/brown_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="6dp"
            android:clipToPadding="false">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    style="@style/Widget.ElMandadito.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todos"
                    android:checked="true"
                    app:chipIcon="@drawable/ic_fire"
                    app:chipIconVisible="true"
                    app:chipIconSize="17dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_mexican"
                    style="@style/Widget.ElMandadito.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mexicana"
                    app:chipIcon="@drawable/ic_food_mexican"
                    app:chipIconVisible="true"
                    app:chipIconSize="17dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_burgers"
                    style="@style/Widget.ElMandadito.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hamburguesas"
                    app:chipIcon="@drawable/ic_food_burger"
                    app:chipIconVisible="true"
                    app:chipIconSize="17dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_pizza"
                    style="@style/Widget.ElMandadito.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pizza"
                    app:chipIcon="@drawable/ic_food_pizza"
                    app:chipIconVisible="true"
                    app:chipIconSize="17dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sushi"
                    style="@style/Widget.ElMandadito.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sushi"
                    app:chipIcon="@drawable/ic_food_sushi"
                    app:chipIconVisible="true"
                    app:chipIconSize="17dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_chicken"
                    style="@style/Widget.ElMandadito.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pollo"
                    app:chipIcon="@drawable/ic_food_chicken"
                    app:chipIconVisible="true"
                    app:chipIconSize="17dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_desserts"
                    style="@style/Widget.ElMandadito.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Postres"
                    app:chipIcon="@drawable/ic_food_dessert"
                    app:chipIconVisible="true"
                    app:chipIconSize="17dp" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- =========== CERCA DE TI =========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="22dp"
            android:paddingBottom="6dp">

            <View
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="@color/primary"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cerca de ti"
                android:textColor="@color/brown_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/text_result_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Sort/Filter row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_active_filters"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Filtros activos"
                android:textColor="@color/primary"
                android:textSize="12sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/btn_sort_filter"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:background="@drawable/bg_filter_btn"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/img_sort_filter"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_sort"
                    android:tint="@color/text_secondary"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/text_sort_filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Ordenar"
                    android:textColor="@color/brown_dark"
                    android:textSize="13sp" />

            </LinearLayout>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_restaurants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="28dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        <!-- No results empty state -->
        <LinearLayout
            android:id="@+id/text_no_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="48dp"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_meta_row"
                android:layout_gravity="center_horizontal">
                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_search"
                    android:tint="@color/divider"
                    android:contentDescription="@null" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Sin resultados"
                android:textColor="@color/brown_dark"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Intenta con otra búsqueda o categoría"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
