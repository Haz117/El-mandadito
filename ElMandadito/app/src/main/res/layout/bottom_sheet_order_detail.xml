<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Handle -->
    <View
        android:layout_width="44dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/divider" />

    <!-- Restaurant header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_meta_row">
            <ImageView
                android:id="@+id/img_order_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_food_mexican"
                android:tint="@color/text_secondary"
                android:contentDescription="@null" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_order_restaurant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Restaurante"
                android:textColor="@color/brown_dark"
                android:textSize="19sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/text_order_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 Jun"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginTop="3dp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp" />

    <!-- Stats grid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_meta_row"
            android:paddingVertical="14dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:id="@+id/text_order_items"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Platillos"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_meta_row"
            android:paddingVertical="14dp"
            android:layout_marginEnd="8dp">
            <TextView
                android:id="@+id/text_order_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0"
                android:textColor="@color/primary"
                android:textSize="22sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_meta_row"
            android:paddingVertical="14dp">
            <ImageView
                android:id="@+id/img_order_payment_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_cash"
                android:tint="@color/text_secondary"
                android:contentDescription="@null" />
            <TextView
                android:id="@+id/text_order_payment_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Efectivo"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Rating -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_meta_row"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu calificación"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView android:id="@+id/detail_star1"
                android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_star_outline"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null" />
            <ImageView android:id="@+id/detail_star2"
                android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_star_outline"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null" />
            <ImageView android:id="@+id/detail_star3"
                android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_star_outline"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null" />
            <ImageView android:id="@+id/detail_star4"
                android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_star_outline"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null" />
            <ImageView android:id="@+id/detail_star5"
                android:layout_width="26dp" android:layout_height="26dp"
                android:src="@drawable/ic_star_outline"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/text_order_rating_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Sin calificar"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/btn_order_again"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_checkout_btn"
            android:text="Pedir de nuevo"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/btn_close_order_detail"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:background="@drawable/bg_meta_row"
            android:text="Cerrar"
            android:textColor="@color/brown_dark"
            android:textSize="14sp"
            android:paddingHorizontal="20dp" />
    </LinearLayout>

</LinearLayout>
