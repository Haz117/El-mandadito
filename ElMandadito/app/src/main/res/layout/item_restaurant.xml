<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="6dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/surface"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:foreground="@drawable/bg_ripple_card">

        <!-- ===== IMAGE AREA ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="170dp">

            <!-- Colored gradient background (set in code) -->
            <View
                android:id="@+id/view_gradient"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Decorative circle: large, top-end -->
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-50dp"
                android:layout_marginEnd="-50dp"
                android:background="#1AFFFFFF" />

            <!-- Decorative circle: small, bottom-start -->
            <View
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="-20dp"
                android:layout_marginBottom="-20dp"
                android:background="#10FFFFFF" />

            <!-- Bottom scrim for badges readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_image_scrim" />

            <!-- Food illustration -->
            <ImageView
                android:id="@+id/img_food"
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:elevation="3dp" />

            <!-- Promo badge — top start -->
            <LinearLayout
                android:id="@+id/layout_promo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="12dp"
                android:background="@drawable/bg_promo_tag"
                android:orientation="horizontal"
                android:paddingHorizontal="9dp"
                android:paddingVertical="5dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:src="@drawable/ic_tag"
                    android:tint="#FFFFFF"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/text_promo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Rating pill — top end -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/bg_frosted_pill"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_star"
                    android:tint="@color/star_color"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/text_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/brown_dark"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Status badge — bottom start -->
            <LinearLayout
                android:id="@+id/layout_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp"
                android:background="@drawable/bg_open_badge"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/dot_status"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/bg_cart_badge"
                    android:backgroundTint="#2E7D32"
                    android:layout_marginEnd="5dp" />

                <TextView
                    android:id="@+id/text_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Abierto"
                    android:textColor="#2E7D32"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Heart button — bottom end -->
            <ImageView
                android:id="@+id/btn_favorite"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="10dp"
                android:src="@drawable/ic_heart_outline"
                android:contentDescription="Favorito"
                android:padding="6dp"
                android:background="@drawable/bg_frosted_pill"
                android:clickable="true"
                android:focusable="true"
                android:elevation="4dp" />

            <!-- Cart count badge -->
            <TextView
                android:id="@+id/badge_cart_count"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="top|start"
                android:layout_margin="10dp"
                android:gravity="center"
                android:background="@drawable/bg_cart_badge"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:elevation="4dp" />

        </FrameLayout>

        <!-- ===== INFO SECTION ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="16dp">

            <!-- Name + arrow -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/text_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/brown_dark"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.01"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/text_hint"
                    android:contentDescription="@null" />
            </LinearLayout>

            <!-- Tags -->
            <TextView
                android:id="@+id/text_tags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Meta row with dots separating items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_meta_row"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <!-- Time -->
                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_clock"
                    android:tint="@color/text_secondary"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/text_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <!-- Dot separator -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="·"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />

                <!-- Delivery -->
                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_delivery"
                    android:tint="@color/success"
                    android:contentDescription="@null" />

                <TextView
                    android:id="@+id/text_delivery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/success"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- Dot separator -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="·"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />

                <!-- Minimum -->
                <TextView
                    android:id="@+id/text_minimum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
